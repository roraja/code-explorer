{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Extension",
      "type": "npm",
      "script": "build:extension",
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Build Webview",
      "type": "npm",
      "script": "build:webview",
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Build All",
      "dependsOn": ["Build Extension", "Build Webview"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Watch Extension",
      "type": "npm",
      "script": "watch:extension",
      "isBackground": true,
      "group": "build",
      "problemMatcher": ["$tsc-watch"]
    },
    {
      "label": "Watch Webview",
      "type": "npm",
      "script": "watch:webview",
      "isBackground": true,
      "group": "build",
      "problemMatcher": ["$tsc-watch"]
    },
    {
      "label": "Watch All",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "group": "build",
      "problemMatcher": ["$tsc-watch"]
    },
    {
      "label": "Run Tests",
      "type": "npm",
      "script": "test",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Lint",
      "type": "npm",
      "script": "lint",
      "group": "test",
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "Package VSIX",
      "type": "npm",
      "script": "package",
      "group": "build",
      "problemMatcher": []
    }
  ]
}
